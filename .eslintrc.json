{
  "env": { "browser": true, "es2021": true, "node": true },
  "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended", "plugin:react/recommended", "plugin:react-hooks/recommended", "next/core-web-vitals"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": { "ecmaVersion": 12, "sourceType": "module" },
  "plugins": ["@typescript-eslint", "react"],
  "rules": { "semi": ["error", "always"], "quotes": ["error", "single"], "@typescript-eslint/no-unused-vars": "warn", "react/prop-types": "off" }
}
