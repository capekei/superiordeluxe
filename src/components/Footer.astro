---
import { SITE_TITLE, CATEGORIES, CONTACT_INFO, SOCIAL_MEDIA, LOGO_URL } from '../consts';
---

<footer class="relative bg-gradient-to-b from-gray-950 to-black text-white pt-8 pb-6 w-full">
	<!-- Elementos decorativos de fondo -->
	<div class="absolute inset-0 grid-bg-2025 opacity-10"></div>
	<div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-accent to-transparent"></div>
	
	<!-- Línea de acento superior con efecto de brillo -->
	<div class="absolute top-0 left-0 w-full h-[1px] glow-line"></div>
	
	<div class="container mx-auto px-4 relative z-20">
		<!-- Footer Grid Principal -->
		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-6 mb-6">
			<!-- Columna 1: Logo e información (ocupa 4 columnas en lg) -->
			<div class="lg:col-span-4 relative">
				<a href="/" class="inline-block mb-4 transform hover:opacity-90">
					<img src={LOGO_URL} alt={SITE_TITLE} class="h-10">
				</a>
				<p class="text-gray-300 mb-4 text-sm leading-relaxed max-w-md">
					Electrodomésticos de alta gama con diseño minimalista e innovación tecnológica para tu hogar.
				</p>
				
				<!-- Redes sociales -->
				<div class="flex space-x-2">
					<a href={SOCIAL_MEDIA.facebook} class="p-1.5 rounded-lg hover:bg-accent/10 text-gray-300 hover:text-white transition-all duration-300">
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd"></path>
						</svg>
					</a>
					<a href={SOCIAL_MEDIA.instagram} class="p-1.5 rounded-lg hover:bg-accent/10 text-gray-300 hover:text-white transition-all duration-300">
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" clip-rule="evenodd"></path>
						</svg>
					</a>
					<a href={SOCIAL_MEDIA.twitter} class="p-1.5 rounded-lg hover:bg-accent/10 text-gray-300 hover:text-white transition-all duration-300">
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84"></path>
						</svg>
					</a>
				</div>
			</div>
			
			<!-- Columna 2: Enlaces rápidos (ocupa 2 columnas en lg) -->
			<div class="lg:col-span-2 footer-links-column">
				<h3 class="text-base font-medium mb-3 relative inline-block text-gradient-2025-light">
					Enlaces
					<div class="absolute -bottom-1 left-0 w-8 h-[1px] bg-accent/80 rounded-full"></div>
				</h3>
				<ul class="space-y-2">
					<li>
						<a href="/" class="footer-link text-sm group">
							<span class="text-white text-opacity-85 group-hover:text-white font-medium transition-colors duration-300">Inicio</span>
						</a>
					</li>
					<li>
						<a href="/productos" class="footer-link text-sm group">
							<span class="text-white text-opacity-85 group-hover:text-white font-medium transition-colors duration-300">Productos</span>
						</a>
					</li>
					<li>
						<a href="/about" class="footer-link text-sm group">
							<span class="text-white text-opacity-85 group-hover:text-white font-medium transition-colors duration-300">Sobre Nosotros</span>
						</a>
					</li>
					<li>
						<a href="/contact" class="footer-link text-sm group">
							<span class="text-white text-opacity-85 group-hover:text-white font-medium transition-colors duration-300">Contacto</span>
						</a>
					</li>
				</ul>
			</div>
			
			<!-- Columna 3: Categorías (ocupa 3 columnas en lg) -->
			<div class="lg:col-span-3 footer-links-column">
				<h3 class="text-base font-medium mb-3 relative inline-block text-gradient-2025-light">
					Categorías
					<div class="absolute -bottom-1 left-0 w-8 h-[1px] bg-accent/80 rounded-full"></div>
				</h3>
				<ul class="space-y-2 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-2">
					{CATEGORIES.map(category => (
						<li>
							<a href={`/categoria/${category.toLowerCase()}`} class="footer-link text-sm group">
								<span class="text-white text-opacity-85 group-hover:text-white font-medium transition-colors duration-300">{category}</span>
							</a>
						</li>
					))}
				</ul>
			</div>
			
			<!-- Columna 4: Contacto (ocupa 3 columnas en lg) -->
			<div class="lg:col-span-3 footer-contact-column">
				<h3 class="text-base font-medium mb-3 relative inline-block text-gradient-2025-light">
					Contacto
					<div class="absolute -bottom-1 left-0 w-8 h-[1px] bg-accent/80 rounded-full"></div>
				</h3>
				<ul class="space-y-3 text-sm">
					<li class="flex items-start group">
						<div class="p-1.5 rounded-lg mr-2 text-accent group-hover:bg-accent/10 transition-all duration-300">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
							</svg>
						</div>
						<div class="text-white text-opacity-85 group-hover:text-white font-medium">
							{CONTACT_INFO.address}
						</div>
					</li>
					<li class="flex items-start group">
						<div class="p-1.5 rounded-lg mr-2 text-accent group-hover:bg-accent/10 transition-all duration-300">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
							</svg>
						</div>
						<div class="text-white text-opacity-85 group-hover:text-white font-medium">
							{CONTACT_INFO.phone}
						</div>
					</li>
					<li class="flex items-start group">
						<div class="p-1.5 rounded-lg mr-2 text-accent group-hover:bg-accent/10 transition-all duration-300">
							<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
							</svg>
						</div>
						<div class="text-white text-opacity-85 group-hover:text-white font-medium">
							{CONTACT_INFO.email}
						</div>
					</li>
				</ul>
			</div>
		</div>
		
		<!-- Separador con efecto de línea brillante -->
		<div class="relative h-px w-full my-4 overflow-hidden">
			<div class="absolute inset-0 bg-gradient-to-r from-transparent via-gray-700 to-transparent"></div>
			<div class="absolute inset-0 bg-gradient-to-r from-transparent via-accent/30 to-transparent blur-sm"></div>
		</div>
		
		<!-- Copyright y enlaces legales -->
		<div class="flex flex-col md:flex-row justify-between items-center text-sm">
			<p class="text-gray-400 mb-2 md:mb-0 font-medium">
				&copy; {new Date().getFullYear()} <span class="text-gradient-2025">{SITE_TITLE}</span>.
			</p>
			<div class="flex space-x-4">
				<a href="/terminos" class="text-gray-400 hover:text-accent font-medium transition-colors duration-300">
					Términos
				</a>
				<a href="/privacidad" class="text-gray-400 hover:text-accent font-medium transition-colors duration-300">
					Privacidad
				</a>
			</div>
		</div>
	</div>
</footer>

<style>
	/* Animaciones para el footer */
	.footer-link {
		transition: transform 0.2s ease;
		display: inline-flex;
		align-items: center;
	}
	
	.footer-link:hover {
		transform: translateX(2px);
	}
	
	.footer-links-column, 
	.footer-contact-column {
		position: relative;
		z-index: 1;
	}
	
	.footer-links-column::before,
	.footer-contact-column::before {
		content: '';
		position: absolute;
		top: -10px;
		left: -10px;
		width: 30px;
		height: 30px;
		background-color: var(--color-accent);
		opacity: 0.03;
		border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
		z-index: -1;
	}
	
	/* Efecto de línea brillante */
	.glow-line {
		background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
		animation: glowingLine 4s infinite;
	}
	
	/* Efecto de subrayado animado */
	.animated-underline {
		position: relative;
	}
	
	.animated-underline::after {
		content: '';
		position: absolute;
		bottom: -2px;
		left: 0;
		width: 0;
		height: 1px;
		background-color: var(--color-accent);
		transition: width 0.2s ease;
	}
	
	.animated-underline:hover::after {
		width: 100%;
	}

	/* Mejora de contraste para legibilidad */
	.text-gradient-2025-light {
		color: white;
		font-weight: 500;
		text-shadow: 0 0 10px rgba(var(--color-accent-rgb), 0.3);
	}
</style>
