---
import { SITE_TITLE } from '../consts';
---

<section class="hero-section relative bg-white dark:bg-slate-900 overflow-hidden">
  <!-- Fondo con cocina moderna de alta gama con estética 2025 -->
  <div class="hero-bg absolute inset-0 z-0">
    <img 
      src="https://images.unsplash.com/photo-1600585152220-90363fe7e115?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=crop&w=1920&q=85" 
      alt="Cocina moderna minimalista de alta gama 2025" 
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-black/80 via-black/50 to-transparent"></div>
    
    <!-- Elementos futuristas superpuestos -->
    <div class="absolute inset-0 grid-overlay"></div>
    <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-black/80 to-transparent"></div>
    
    <!-- Partículas animadas para efecto moderno -->
    <div class="particles-container absolute inset-0 z-1 opacity-30"></div>
  </div>
  
  <div class="w-full px-4 py-16 md:py-24 lg:py-32 relative z-10">
    <div class="max-w-5xl mx-auto">
        <div class="neo-glass-card p-8 md:p-12 backdrop-blur-xl border-l border-red-500/30">
          <div class="futuristic-accent absolute -top-2 -left-2 w-16 h-16 opacity-60"></div>
          <div class="futuristic-corner absolute top-0 right-0"></div>
          <div class="glowing-line"></div>
          
          <h1 class="text-4xl md:text-5xl lg:text-7xl font-bold text-white mb-6">
            <span class="block font-light text-red-500/90 tracking-tight future-text">Visión 2025</span>
            <span class="block mt-2 tracking-tight gradient-text">Electrodomésticos de Alta Gama</span>
          </h1>

          <p class="text-lg md:text-xl text-white/90 mb-8 max-w-2xl font-light leading-relaxed">
            Descubre nuestra colección exclusiva con diseño minimalista e innovación tecnológica 
            que transformará tu hogar en un espacio moderno y funcional.
          </p>

          <div class="flex flex-col sm:flex-row gap-4">
            <a 
              href="/catalogo" 
              class="
                neo-btn px-8 py-4 bg-red-600/90 text-white font-medium rounded-lg
                transition-all duration-300 
                hover:bg-red-500 hover:shadow-red-500
                focus:outline-none focus:ring-2 focus:ring-red-500/50
                relative overflow-hidden group
              "
            >
              <span class="relative z-10 flex items-center justify-center">
                Ver Catálogo
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </span>
              <span class="ripple-effect"></span>
            </a>
            <a 
              href="#categorias" 
              class="
                neo-outline-btn px-8 py-4 border border-white/20 text-white font-medium rounded-lg
                transition-all duration-300 backdrop-blur-sm bg-white/5
                hover:bg-white/10 hover:border-white/30
                focus:outline-none focus:ring-2 focus:ring-white/30
                group
              "
            >
              <span class="flex items-center justify-center">
                Explorar Categorías
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2 transform group-hover:translate-y-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                </svg>
              </span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: calc(100vh - var(--header-height));
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
  }

  .hero-bg img {
    filter: brightness(0.9) saturate(1.1) contrast(1.05);
  }

  .neo-glass-card {
    background: rgba(20, 30, 48, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(16px);
  }

  .product-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.08);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
    border-color: rgba(255, 255, 255, 0.1);
  }

  /* Futuristic accent elements */
  .futuristic-accent {
    background: linear-gradient(135deg, var(--color-accent), transparent);
    clip-path: polygon(0 0, 100% 0, 80% 100%, 0 80%);
    z-index: -1;
  }

  .futuristic-corner {
    width: 80px;
    height: 80px;
    background: linear-gradient(315deg, var(--color-accent) 0%, transparent 60%);
    clip-path: polygon(100% 0, 100% 100%, 0 0);
    opacity: 0.3;
    z-index: -1;
  }

  .future-text {
    position: relative;
    display: inline-block;
  }

  .future-text::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 0;
    width: 40%;
    height: 1px;
    background: linear-gradient(90deg, var(--color-accent), transparent);
  }

  /* Gradient text effect */
  .gradient-text {
    background: linear-gradient(90deg, #ffffff, #e0e0e0);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    text-shadow: 0 0 20px rgba(255, 255, 255, 0.15);
  }

  /* Grid overlay for futuristic effect */
  .grid-overlay {
    background-image: 
      linear-gradient(to right, rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse at center, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0) 70%);
  }

  /* Glowing line effect */
  .glowing-line {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
    animation: glowingLine 4s infinite;
  }

  @keyframes glowingLine {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  /* Card glow effect */
  .card-glow {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(var(--color-accent-rgb), 0.3) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }

  .product-card:hover .card-glow {
    opacity: 0.4;
  }

  /* Neo buttons with 2025 aesthetic */
  .neo-btn {
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(var(--color-accent-rgb), 0.3);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .neo-btn:hover {
    box-shadow: 0 8px 30px rgba(var(--color-accent-rgb), 0.4);
    transform: translateY(-3px);
  }

  .neo-btn::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(45deg, var(--color-accent), transparent);
    z-index: -1;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .neo-btn:hover::before {
    opacity: 0.4;
  }

  .neo-outline-btn {
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .neo-outline-btn:hover {
    box-shadow: 0 5px 20px rgba(255, 255, 255, 0.1);
    transform: translateY(-3px);
  }

  /* Ripple effect for button */
  .ripple-effect {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.4) 1%, transparent 1%) center/15000%;
    opacity: 0;
    transition: opacity 0.5s, background-size 0.5s;
  }

  .neo-btn:active .ripple-effect {
    opacity: 0.3;
    background-size: 100%;
    transition: 0s;
  }

  /* Particles container */
  .particles-container {
    overflow: hidden;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .hero-section {
      text-align: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-card:hover {
      transform: none;
    }
    
    .neo-btn:hover,
    .neo-outline-btn:hover {
      transform: none;
    }
    
    .glowing-line {
      animation: none;
    }
  }
</style>

<script is:inline>
  // Parallax effect for hero background
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const heroSection = document.querySelector('.hero-section');
    const heroBg = document.querySelector('.hero-bg img');
    
    if (heroSection && heroBg) {
      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;
        const speed = 0.15; // Parallax factor
        
        heroBg.style.transform = `translateY(${scrollY * speed}px)`;
      });
    }
  }

  // Add subtle animation for futuristic elements
  document.addEventListener('DOMContentLoaded', () => {
    const futureText = document.querySelector('.future-text');
    if (futureText && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      // Add subtle glow animation
      setInterval(() => {
        if (futureText instanceof HTMLElement) {
          futureText.style.textShadow = '0 0 12px rgba(var(--color-accent-rgb), 0.6)';
          setTimeout(() => {
            futureText.style.textShadow = 'none';
          }, 1000);
        }
      }, 3000);
    }
    
    // Add floating grid effect
    const gridOverlay = document.querySelector('.grid-overlay');
    if (gridOverlay && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      let offset = 0;
      setInterval(() => {
        offset += 0.15;
        if (gridOverlay instanceof HTMLElement) {
          gridOverlay.style.backgroundPosition = `${offset}px ${offset}px`;
        }
      }, 50);
    }
    
    // Add hover effect for neo-glass-card
    const neoGlassCard = document.querySelector('.neo-glass-card');
    if (neoGlassCard && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      neoGlassCard.addEventListener('mousemove', (e) => {
        if (neoGlassCard instanceof HTMLElement && e instanceof MouseEvent) {
          const rect = neoGlassCard.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          
          const centerX = rect.width / 2;
          const centerY = rect.height / 2;
          
          const angleX = (y - centerY) / 30;
          const angleY = (centerX - x) / 30;
          
          neoGlassCard.style.transform = `perspective(1000px) rotateX(${angleX}deg) rotateY(${angleY}deg)`;
        }
      });
      
      neoGlassCard.addEventListener('mouseleave', () => {
        if (neoGlassCard instanceof HTMLElement) {
          neoGlassCard.style.transform = 'perspective(1000px) rotateX(0) rotateY(0)';
        }
      });
    }
    
    // Create animated particles for modern effect
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      const particlesContainer = document.querySelector('.particles-container');
      if (particlesContainer) {
        const particleCount = 25;
        
        for (let i = 0; i < particleCount; i++) {
          const particle = document.createElement('div');
          particle.classList.add('particle');
          
          // Random size between 1-3px
          const size = Math.random() * 2 + 1;
          
          // Random position
          const posX = Math.random() * 100;
          const posY = Math.random() * 100;
          
          // Random opacity
          const opacity = Math.random() * 0.4 + 0.1;
          
          // Random animation duration
          const duration = Math.random() * 20 + 10;
          
          // Set styles
          particle.style.cssText = `
            position: absolute;
            width: ${size}px;
            height: ${size}px;
            background: white;
            border-radius: 50%;
            left: ${posX}%;
            top: ${posY}%;
            opacity: ${opacity};
            box-shadow: 0 0 ${size * 2}px rgba(255, 255, 255, 0.6);
            animation: float ${duration}s infinite ease-in-out;
            animation-delay: ${Math.random() * 5}s;
          `;
          
          particlesContainer.appendChild(particle);
        }
        
        // Add keyframes for float animation
        const style = document.createElement('style');
        style.textContent = `
          @keyframes float {
            0%, 100% { transform: translateY(0) translateX(0); }
            25% { transform: translateY(-20px) translateX(10px); }
            50% { transform: translateY(-10px) translateX(-10px); }
            75% { transform: translateY(-30px) translateX(5px); }
          }
        `;
        document.head.appendChild(style);
      }
    }
  });
</script>
