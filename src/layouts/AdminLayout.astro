---
import BaseHead from '../components/BaseHead.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const { title = 'Panel de Administración', description = 'Gestiona tu inventario de productos' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<BaseHead title={`${title} - ${SITE_TITLE}`} description={description} />
	</head>
	<body class="bg-gray-100 min-h-screen flex flex-col">
        <div class="flex min-h-screen">
            <!-- Sidebar -->
            <div class="w-64 bg-white shadow-md">
                <div class="p-4 flex justify-center">
                    <!-- Commented out logo
                    <img class="h-10" src="/images/logo-superior.svg" alt="Superior Deluxe" />
                    -->
                </div>
                <nav class="mt-6">
                    <div class="px-4 py-2">
                        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide">
                            Principal
                        </div>
                        <div class="mt-2 -mx-3">
                            <a href="/admin" class={`flex items-center justify-between px-3 py-2 rounded-lg hover:bg-gray-100 ${Astro.url.pathname === '/admin' ? 'bg-red-50 text-red-700' : 'text-gray-700'}`}>
                                <span class="flex items-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                                    </svg>
                                    <span>Dashboard</span>
                                </span>
                            </a>
                            <a href="/admin/inventory" class={`flex items-center justify-between px-3 py-2 rounded-lg hover:bg-gray-100 ${Astro.url.pathname.includes('/admin/inventory') ? 'bg-red-50 text-red-700' : 'text-gray-700'}`}>
                                <span class="flex items-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                    </svg>
                                    <span>Inventario</span>
                                </span>
                            </a>
                            <a href="/admin/categories" class={`flex items-center justify-between px-3 py-2 rounded-lg hover:bg-gray-100 ${Astro.url.pathname === '/admin/categories' ? 'bg-red-50 text-red-700' : 'text-gray-700'}`}>
                                <span class="flex items-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                    </svg>
                                    <span>Categorías</span>
                                </span>
                            </a>
                        </div>
                    </div>

                    <div class="px-4 py-2 mt-4">
                        <div class="text-xs font-semibold text-gray-400 uppercase tracking-wide">
                            Configuración
                        </div>
                        <div class="mt-2 -mx-3">
                            <a href="/admin/settings" class={`flex items-center justify-between px-3 py-2 rounded-lg hover:bg-gray-100 ${Astro.url.pathname === '/admin/settings' ? 'bg-red-50 text-red-700' : 'text-gray-700'}`}>
                                <span class="flex items-center">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                    <span>Ajustes</span>
                                </span>
                            </a>
                        </div>
                    </div>
                </nav>

                <div class="px-4 py-2 mt-auto mb-4">
                    <div class="border-t pt-4">
                        <button id="logoutButton" class="w-full flex items-center px-3 py-2 text-red-600 hover:bg-red-50 rounded-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                            </svg>
                            <span>Cerrar Sesión</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="flex-1 flex flex-col overflow-hidden">
                <!-- Header -->
                <header class="bg-white shadow-sm z-10">
                    <div class="px-4 py-3 flex justify-between items-center">
                        <div>
                            <h1 class="text-lg font-medium text-gray-900">{title}</h1>
                        </div>
                        <div class="flex items-center space-x-4">
                            <div class="relative">
                                <a href="/" target="_blank" class="flex items-center text-gray-700 hover:text-red-600">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                    </svg>
                                    <span class="text-sm">Ver Sitio</span>
                                </a>
                            </div>
                        </div>
                    </div>
                </header>

                <!-- Page Content -->
                <main class="flex-1 overflow-auto bg-gray-100 p-4">
                    <slot />
                </main>
            </div>
        </div>

        <script is:inline>
            document.addEventListener('DOMContentLoaded', () => {
                // Verificar autenticación
                const isAuthenticated = localStorage.getItem('adminAuthenticated') === 'true';
                
                if (!isAuthenticated && !window.location.pathname.includes('/admin/login')) {
                    window.location.href = '/admin/login';
                }
                
                // Configurar cierre de sesión
                const logoutButton = document.getElementById('logoutButton');
                logoutButton?.addEventListener('click', () => {
                    localStorage.removeItem('adminAuthenticated');
                    localStorage.removeItem('adminLastLogin');
                    window.location.href = '/admin/login';
                });
            });
        </script>
	</body>
</html>
