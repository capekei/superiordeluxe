---
import AdminLayout from '../../layouts/AdminLayout.astro';

// Configuración inicial
const initialSettings = {
  siteName: 'Superior Deluxe',
  siteDescription: 'Electrodomésticos de alta calidad para tu hogar y negocio',
  contactEmail: 'info@superiordeluxe.com',
  contactPhone: '+1 (555) 123-4567',
  address: 'Calle Principal #123, Ciudad',
  socialMedia: {
    facebook: 'https://facebook.com/superiordeluxe',
    instagram: 'https://instagram.com/superiordeluxe',
    twitter: 'https://twitter.com/superiordeluxe'
  },
  featuredProductsCount: 4
};
---

<AdminLayout title="Configuración del Sitio">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Configuración del Sitio</h1>
    <p class="text-gray-600 mt-1">Administra la configuración general de tu tienda.</p>
  </div>
  
  <div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <form id="settingsForm" class="space-y-6">
      <div>
        <h2 class="text-lg font-semibold mb-4">Información General</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="siteName" class="block text-sm font-medium text-gray-700 mb-1">Nombre del Sitio</label>
            <input 
              type="text" 
              id="siteName" 
              name="siteName" 
              value={initialSettings.siteName}
              required
              class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-red-500 focus:border-red-500"
            />
          </div>
          
          <div>
            <label for="featuredProductsCount" class="block text-sm font-medium text-gray-700 mb-1">Productos Destacados en Inicio</label>
            <input 
              type="number" 
              id="featuredProductsCount" 
              name="featuredProductsCount" 
              value={initialSettings.featuredProductsCount}
              min="1"
              max="8"
              required
              class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-red-500 focus:border-red-500"
            />
          </div>
        </div>
        
        <div class="mt-4">
          <label for="siteDescription" class="block text-sm font-medium text-gray-700 mb-1">Descripción del Sitio</label>
          <textarea 
            id="siteDescription" 
            name="siteDescription" 
            rows="3" 
            class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-red-500 focus:border-red-500"
          >{initialSettings.siteDescription}</textarea>
        </div>
      </div>
      
      <hr class="my-6" />
      
      <div>
        <h2 class="text-lg font-semibold mb-4">Información de Contacto</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="contactEmail" class="block text-sm font-medium text-gray-700 mb-1">Email de Contacto</label>
            <input 
              type="email" 
              id="contactEmail" 
              name="contactEmail" 
              value={initialSettings.contactEmail}
              required
              class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-red-500 focus:border-red-500"
            />
          </div>
          
          <div>
            <label for="contactPhone" class="block text-sm font-medium text-gray-700 mb-1">Teléfono de Contacto</label>
            <input 
              type="text" 
              id="contactPhone" 
              name="contactPhone" 
              value={initialSettings.contactPhone}
              class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-red-500 focus:border-red-500"
            />
          </div>
        </div>
        
        <div class="mt-4">
          <label for="address" class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
          <input 
            type="text" 
            id="address" 
            name="address" 
            value={initialSettings.address}
            class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-red-500 focus:border-red-500"
          />
        </div>
      </div>
      
      <hr class="my-6" />
      
      <div>
        <h2 class="text-lg font-semibold mb-4">Redes Sociales</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="facebook" class="block text-sm font-medium text-gray-700 mb-1">Facebook</label>
            <input 
              type="url" 
              id="facebook" 
              name="facebook" 
              value={initialSettings.socialMedia.facebook}
              class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-red-500 focus:border-red-500"
            />
          </div>
          
          <div>
            <label for="instagram" class="block text-sm font-medium text-gray-700 mb-1">Instagram</label>
            <input 
              type="url" 
              id="instagram" 
              name="instagram" 
              value={initialSettings.socialMedia.instagram}
              class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-red-500 focus:border-red-500"
            />
          </div>
          
          <div>
            <label for="twitter" class="block text-sm font-medium text-gray-700 mb-1">Twitter</label>
            <input 
              type="url" 
              id="twitter" 
              name="twitter" 
              value={initialSettings.socialMedia.twitter}
              class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-red-500 focus:border-red-500"
            />
          </div>
        </div>
      </div>
      
      <div class="flex justify-end pt-6">
        <button 
          type="submit"
          class="px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500"
        >
          Guardar Configuración
        </button>
      </div>
    </form>
  </div>
</AdminLayout>

<script is:inline>
  // Configuración inicial
  let settings = {
    siteName: 'Superior Deluxe',
    siteDescription: 'Electrodomésticos de alta calidad para tu hogar y negocio',
    contactEmail: 'info@superiordeluxe.com',
    contactPhone: '+1 (555) 123-4567',
    address: 'Calle Principal #123, Ciudad',
    socialMedia: {
      facebook: 'https://facebook.com/superiordeluxe',
      instagram: 'https://instagram.com/superiordeluxe',
      twitter: 'https://twitter.com/superiordeluxe'
    },
    featuredProductsCount: 4
  };
  
  // Cargar configuración guardada si existe
  function loadSettings() {
    const savedSettings = localStorage.getItem('siteSettings');
    if (savedSettings) {
      try {
        const parsedSettings = JSON.parse(savedSettings);
        settings = { ...settings, ...parsedSettings };
        
        // Actualizar formulario con valores guardados
        updateFormValues();
      } catch (error) {
        console.error('Error al cargar la configuración guardada:', error);
      }
    }
  }
  
  // Actualizar valores del formulario
  function updateFormValues() {
    document.getElementById('siteName').value = settings.siteName || '';
    document.getElementById('siteDescription').value = settings.siteDescription || '';
    document.getElementById('contactEmail').value = settings.contactEmail || '';
    document.getElementById('contactPhone').value = settings.contactPhone || '';
    document.getElementById('address').value = settings.address || '';
    document.getElementById('facebook').value = settings.socialMedia?.facebook || '';
    document.getElementById('instagram').value = settings.socialMedia?.instagram || '';
    document.getElementById('twitter').value = settings.socialMedia?.twitter || '';
    document.getElementById('featuredProductsCount').value = settings.featuredProductsCount || 4;
  }
  
  // Manejar envío del formulario
  function handleSettingsFormSubmit(e) {
    e.preventDefault();
    
    const form = e.currentTarget;
    const formData = new FormData(form);
    
    // Actualizar configuración
    settings.siteName = formData.get('siteName');
    settings.siteDescription = formData.get('siteDescription');
    settings.contactEmail = formData.get('contactEmail');
    settings.contactPhone = formData.get('contactPhone');
    settings.address = formData.get('address');
    settings.socialMedia = {
      facebook: formData.get('facebook'),
      instagram: formData.get('instagram'),
      twitter: formData.get('twitter')
    };
    settings.featuredProductsCount = parseInt(formData.get('featuredProductsCount') || '4');
    
    // Guardar configuración en localStorage
    localStorage.setItem('siteSettings', JSON.stringify(settings));
    
    // Mostrar mensaje de éxito
    alert('Configuración guardada correctamente');
  }
  
  // Event listeners
  document.addEventListener('DOMContentLoaded', () => {
    // Cargar configuración
    loadSettings();
    
    // Formulario
    const settingsForm = document.getElementById('settingsForm');
    settingsForm?.addEventListener('submit', handleSettingsFormSubmit);
  });
</script> 